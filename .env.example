SERVER_PORT=8085
DATABASE_URL=postgres://postgres:postgres@localhost:5433/ticketbooking?sslmode=disable
# Redis — pick one:
#
# TLS Redis (Upstash, Elasticache in-transit, etc.): use rediss:// exactly as your provider documents.
# Upstash: https://console.upstash.com → copy the URL that starts with rediss://
# Example: rediss://default:YOUR_TOKEN@us1-allowed-mollusk-12345.upstash.io:6379
#
# Local Docker: docker compose up -d redis
# REDIS_URL=redis://localhost:6379
REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_ENDPOINT.upstash.io:6379
RESERVATION_TTL_MINUTES=2
RESERVATION_MAX_SEATS=100
GIN_MODE=debug
